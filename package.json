{
  "name": "openrouter-chat",
  "version": "1.0.0",
  "description": "Beautiful OpenRouter chat desktop app with model compare",
  "license": "MIT",
  "homepage": "https://github.com/gorarakelyanf/openrouter-chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/gorarakelyanf/openrouter-chat.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "highlight.js": "^11.10.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.openrouter.chat",
    "productName": "OpenRouter Chat",
    "artifactName": "OpenRouter-Chat-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenRouter Chat"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "OpenRouter-Chat-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "OpenRouter-Chat-${version}.${ext}"
    }
  }
}
